# Docker Compose project
COMPOSE_PROJECT_NAME=quro
QRO_FRONTEND_PORT=80

# Database
POSTGRES_DB=quro
POSTGRES_ADMIN_USER=quro_admin
POSTGRES_APP_USER=quro_app

# Object storage
MINIO_ROOT_USER=quro_root
MINIO_APP_USER=quro_app
S3_BUCKET=quro-documents
S3_REGION=eu-west-1
S3_FORCE_PATH_STYLE=true

# Core app runtime
# Set SECURE_COOKIES=true when the app is served over HTTPS (TLS terminated at proxy/CDN)
SECURE_COOKIES=false
CORS_ORIGIN=http://localhost,http://localhost:5173
PENSION_PARSER_INTERNAL_URL=http://pension-parser:8080
PENSION_PARSER_TIMEOUT_MS=300000
IMPORT_DRAFT_TTL_DAYS=7
IMPORT_WORKER_POLL_INTERVAL_MS=3000

# Optional pension-import profile
PARSER_ALLOW_REGEX_FALLBACK=true
PARSER_REGEX_ONLY=false
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
VLLM_TIMEOUT_SECONDS=180
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_MAX_MODEL_LEN=8192
VLLM_INTERNAL_BASE_URL=http://vllm:8000
