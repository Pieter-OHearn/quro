{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@quro/shared": ["../shared/src"]
    },
    "baseUrl": "."
  },
  "include": ["src"]
}
