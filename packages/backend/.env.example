# Contributor/local Bun workflow only.
# Public Docker setup uses the repo root .env file and secrets/*.txt instead.

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Shared fallback URL. If you do not set split-role URLs below, runtime and admin scripts use this.
DATABASE_URL=

# Recommended split-role URLs for local safety.
ADMIN_DATABASE_URL=
APP_DATABASE_URL=

# Optional explicit runtime-role credentials used by db:bootstrap-runtime-role.
APP_DB_USER=
APP_DB_PASSWORD=

# Optional superuser URL if ADMIN_DATABASE_URL cannot create roles.
BOOTSTRAP_DATABASE_URL=

# Comma-separated browser origins allowed to access the backend directly.
# This covers the Docker/nginx shell on http://localhost and split Vite dev on http://localhost:5173.
CORS_ORIGIN=http://localhost,http://localhost:5173
# In local dev set this to http://localhost:5173 so OAuth redirects land on the Vite dev server.
# Leave empty in production where nginx serves frontend and backend on the same origin.
FRONTEND_ORIGIN=
PORT=3000

MARKETSTACK_API_KEY=

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=eu-west-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

PENSION_PARSER_URL=http://127.0.0.1:8080
PENSION_PARSER_TIMEOUT_MS=300000
IMPORT_DRAFT_TTL_DAYS=7
IMPORT_WORKER_POLL_INTERVAL_MS=3000
PARSER_ALLOW_REGEX_FALLBACK=true
PARSER_REGEX_ONLY=false
VLLM_BASE_URL=http://127.0.0.1:8000
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
VLLM_TIMEOUT_SECONDS=180
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_MAX_MODEL_LEN=8192
HUGGING_FACE_HUB_TOKEN=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

BUNQ_CLIENT_ID=
BUNQ_CLIENT_SECRET=
BUNQ_REDIRECT_URI=
BUNQ_SANDBOX=true
