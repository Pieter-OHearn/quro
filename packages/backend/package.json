{
  "name": "@quro/backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "worker:pension-imports": "bun run src/workers/pensionImportWorker.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:backup": "bun run src/db/backup.ts",
    "db:restore": "bun run src/db/restore.ts",
    "db:clear": "bun run src/db/clear.ts",
    "db:bootstrap-runtime-role": "bun run src/db/bootstrapRuntimeRole.ts",
    "db:seed-demo": "bun run src/db/seedDemoUser.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@quro/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
