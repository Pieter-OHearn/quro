{
  "name": "quro",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@quro/*' dev",
    "dev:frontend": "bun run --filter '@quro/frontend' dev",
    "dev:backend": "bun run --filter '@quro/backend' dev",
    "smoke:frontend": "bun run --filter '@quro/frontend' dev -- --host 127.0.0.1 --port 4273",
    "smoke:backend": "bun run --filter '@quro/backend' db:migrate && bun run --filter '@quro/backend' db:seed-demo && bun run --filter '@quro/backend' start",
    "build": "bun run --filter '@quro/frontend' build && bun run --filter '@quro/backend' build",
    "typecheck": "bun run --filter '@quro/shared' typecheck && bun run --filter '@quro/frontend' typecheck && bun run --filter '@quro/backend' typecheck",
    "check:format": "prettier --check .",
    "check:lint": "bunx eslint packages --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts",
    "check:typecheck": "bun run typecheck",
    "check:test": "bun run test",
    "check:build": "bun run build",
    "check:python:format": "ruff format --check services/pension-parser/",
    "check:python:lint": "ruff check services/pension-parser/",
    "check:python:build": "python3 -m compileall services/pension-parser/app/",
    "check:security:js": "bun audit",
    "check:security:python": "pip-audit -r services/pension-parser/requirements.txt",
    "ci:check": "sh ./scripts/run-ci-checks.sh",
    "hooks:install": "sh ./scripts/install-git-hooks.sh",
    "test": "sh ./scripts/run-bun-tests.sh",
    "test:smoke": "bunx playwright test",
    "test:ui": "bun run --filter '@quro/frontend' test",
    "db:migrate": "bun run --filter '@quro/backend' db:migrate",
    "db:backup": "bun run --filter '@quro/backend' db:backup",
    "db:restore": "bun run --filter '@quro/backend' db:restore",
    "db:clear": "bun run --filter '@quro/backend' db:clear",
    "db:bootstrap-runtime-role": "bun run --filter '@quro/backend' db:bootstrap-runtime-role",
    "lint:fix": "bunx eslint packages --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --fix",
    "format": "prettier --write .",
    "version:bump": "bun scripts/bump-version.ts",
    "version:verify": "bun scripts/verify-version-bump.ts"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "eslint-plugin-import/minimatch/brace-expansion": "1.1.13",
    "eslint-plugin-react/minimatch/brace-expansion": "1.1.13",
    "fast-xml-parser": "5.5.8",
    "flatted": "3.4.2",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
