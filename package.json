{
  "name": "quro",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@quro/*' dev",
    "dev:frontend": "bun run --filter '@quro/frontend' dev",
    "dev:backend": "bun run --filter '@quro/backend' dev",
    "build": "bun run --filter '@quro/frontend' build && bun run --filter '@quro/backend' build",
    "typecheck": "bun run --filter '@quro/shared' typecheck && bun run --filter '@quro/frontend' typecheck && bun run --filter '@quro/backend' typecheck",
    "check:format": "prettier --check .",
    "check:lint": "bunx eslint packages --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts",
    "check:typecheck": "bun run typecheck",
    "check:test": "bun run test",
    "check:build": "bun run build",
    "check:python:format": "ruff format --check services/pension-parser/",
    "check:python:lint": "ruff check services/pension-parser/",
    "check:python:build": "python3 -m compileall services/pension-parser/app/",
    "check:security:js": "bun audit",
    "check:security:python": "pip-audit -r services/pension-parser/requirements.txt",
    "ci:check": "sh ./scripts/run-ci-checks.sh",
    "hooks:install": "sh ./scripts/install-git-hooks.sh",
    "test": "bun test",
    "test:ui": "bun run --filter '@quro/frontend' test",
    "db:migrate": "bun run --filter '@quro/backend' db:migrate",
    "db:seed": "bun run --filter '@quro/backend' db:seed",
    "lint:fix": "bunx eslint packages --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --fix",
    "format": "prettier --write ."
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
